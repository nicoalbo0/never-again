# never-again configuration — copy to `.env` and uncomment what you need.
#
# Every setting is optional; the defaults shown give you a fully working,
# zero-infrastructure local setup. Real environment variables always take
# precedence over this file, so an MCP client's `env` block is never
# overridden by a stray .env.
#
# This file is read by the CLI and during local development. The MCP server is
# launched by your agent's client (not from your project folder), so it will NOT
# pick up a bare .env from a project directory. To use this file with the MCP
# server, set NEVER_AGAIN_ENV_FILE to its absolute path in your MCP config's
# `env` block, or just put the settings directly in that `env` block.

# --- Storage ---------------------------------------------------------------
# Where failures are stored. Default: ~/.never-again/failures.db
# NEVER_AGAIN_DB=~/.never-again/failures.db

# Backend store. "sqlite" (default) or "postgres" (team server only).
# NEVER_AGAIN_STORE=sqlite

# --- Search ----------------------------------------------------------------
# How errors are matched:
#   fts    keyword search only (default, zero extra dependencies)
#   local  in-process semantic search   (pip install "never-again[local]")
#   ollama semantic search via Ollama   (pip install "never-again[ollama]")
# NEVER_AGAIN_EMBEDDER=fts

# Prevention rules (WHEN / CHECK / BECAUSE) are written by the logging agent
# itself — it has the full context of the fix. There is nothing to configure
# here. When no rule is supplied (e.g. the CLI), one is formatted from the
# provided fields automatically.

# --- Relevance floors ------------------------------------------------------
# Tune how strict matching is before a result is returned at all.
# Higher = stricter = fewer but more relevant results.
# NEVER_AGAIN_COSINE_FLOOR=0.45   # semantic path (embedder=local/ollama)
# NEVER_AGAIN_FUSED_FLOOR=0.10    # keyword path  (embedder=fts)

# --- Ollama (only used when EMBEDDER is "ollama") --------------------------
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Team sharing (optional, server tier) ----------------------------------
# Point at a running team server; when set, tools talk to it instead of the
# local SQLite file. See deploy/ for the server.
# NEVER_AGAIN_URL=https://never-again.your-team.example
# NEVER_AGAIN_TEAM=your-team-slug

# --- Cold-start seeding (optional) -----------------------------------------
# If set and the repo has a GitHub remote, first-run seeding also pulls error
# text from closed issues. Plain git-history seeding needs no token.
# GITHUB_TOKEN=
